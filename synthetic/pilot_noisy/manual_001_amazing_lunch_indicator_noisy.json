  "dialogue": [
    {
      "turn_id": 1,
      "role": "bot",
      "text": "What kind of system do you want?"
    },
    {
      "turn_id": 2,
      "role": "user",
      "text": "Basically a phone app for finding food spots near me and checking what each place offers."
    },
    {
      "turn_id": 3,
      "role": "bot",
      "text": "Who will use it?"
    },
    {
      "turn_id": 4,
      "role": "user",
      "text": "Regular app users, restaurant people using the portal, and whoever manages the whole thing."
    },
    {
      "turn_id": 5,
      "role": "bot",
      "text": "What should users be able to do?"
    },
    {
      "turn_id": 6,
      "role": "user",
      "text": "People should be able to look up places to eat, bounce between map and list results, open the full place details, and get directions. The restaurant side should update venue info, and management should approve those restaurant accounts."
    },
    {
      "turn_id": 7,
      "role": "bot",
      "text": "Do users need login or authentication?"
    },
    {
      "turn_id": 8,
      "role": "user",
      "text": "Yeah, the mobile side needs sign-in, and the portal side needs accounts too for the restaurant side and the people running it."
    },
    {
      "turn_id": 9,
      "role": "bot",
      "text": "Are there performance requirements?"
    },
    {
      "turn_id": 10,
      "role": "user",
      "text": "Searches need to feel quick, like two seconds tops, and if GPS or the internet dies the app should say so instead of just hanging."
    },
    {
      "turn_id": 11,
      "role": "bot",
      "text": "Are there security requirements?"
    },
    {
      "turn_id": 12,
      "role": "user",
      "text": "Login traffic needs protecting, and after three bad tries the portal account should cool off for about thirty minutes."
    }
  ],
