  "dialogue": [
    {
      "turn_id": 1,
      "role": "bot",
      "text": "What kind of system do you want?"
    },
    {
      "turn_id": 2,
      "role": "user",
      "text": "A password vault tool so people can keep account creds together safely."
    },
    {
      "turn_id": 3,
      "role": "bot",
      "text": "Who will use it?"
    },
    {
      "turn_id": 4,
      "role": "user",
      "text": "Mostly regular users, plus IT admins in some cases."
    },
    {
      "turn_id": 5,
      "role": "bot",
      "text": "What should users be able to do?"
    },
    {
      "turn_id": 6,
      "role": "user",
      "text": "They need to spin up and unlock encrypted vaults, find saved items, tweak entries, and move password data in or out."
    },
    {
      "turn_id": 7,
      "role": "bot",
      "text": "Do users need login or authentication?"
    },
    {
      "turn_id": 8,
      "role": "user",
      "text": "Yep, access should rely on a master password, and maybe a key file too if they set up that combined key option."
    },
    {
      "turn_id": 9,
      "role": "bot",
      "text": "Are there performance requirements?"
    },
    {
      "turn_id": 10,
      "role": "user",
      "text": "If someone copies a password, don't leave it sitting around in memory for more than ten seconds."
    },
    {
      "turn_id": 11,
      "role": "bot",
      "text": "Are there security requirements?"
    },
    {
      "turn_id": 12,
      "role": "user",
      "text": "Everything should stay encrypted, the vault must not open without the needed master password or key file, and there should be no recovery backdoor."
    }
  ],
