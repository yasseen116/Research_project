  "dialogue": [
    {
      "turn_id": 1,
      "role": "bot",
      "text": "What kind of system do you want?"
    },
    {
      "turn_id": 2,
      "role": "user",
      "text": "A restaurant menu and ordering system for tables, waiters, and kitchen staff."
    },
    {
      "turn_id": 3,
      "role": "bot",
      "text": "Who will use it?"
    },
    {
      "turn_id": 4,
      "role": "user",
      "text": "Customers, waiters, chefs, and supervisors."
    },
    {
      "turn_id": 5,
      "role": "bot",
      "text": "What should users be able to do?"
    },
    {
      "turn_id": 6,
      "role": "user",
      "text": "Customers should place orders and call waiters, waiters should process cash or bankcard payments, chefs should mark items ready, and supervisors should be able to issue refunds."
    },
    {
      "turn_id": 7,
      "role": "bot",
      "text": "Do users need login or authentication?"
    },
    {
      "turn_id": 8,
      "role": "user",
      "text": "Staff on tablets should log in with usernames and passwords, but customers on the surface computers should not need login."
    },
    {
      "turn_id": 9,
      "role": "bot",
      "text": "Are there performance requirements?"
    },
    {
      "turn_id": 10,
      "role": "user",
      "text": "The server should support at least 200 connected devices, and active orders or payments must never get lost."
    },
    {
      "turn_id": 11,
      "role": "bot",
      "text": "Are there security requirements?"
    },
    {
      "turn_id": 12,
      "role": "user",
      "text": "Wireless communication needs encryption, and each waiter should only be logged into one tablet at a time."
    }
  ],
